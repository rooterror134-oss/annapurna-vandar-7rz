  if(!name||!date||!time||!addr){ showToast('Please fill Name, Date, Time & Address',true); return; }

  const fDate=new Date(date).toLocaleDateString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const [h,m]=time.split(':'); const hr=parseInt(h);
  const fTime=`${hr%12||12}:${m} ${hr>=12?'PM':'AM'}`;

  // Save booking
  const bk={id:Date.now(),name,date:fDate,time:fTime,addr,phone:phone||'—',status:'new'};
  bookings.push(bk);

  // WhatsApp message
  const msg=
    `🌺 *ANNAPURNA VANDAR WORK*\n`+
