/* ══════════════════════════════════════
   HERO CANVAS ANIMATION
══════════════════════════════════════ */
const canvas=document.getElementById('hero-canvas');
const ctx=canvas.getContext('2d');
function resize(){ canvas.width=window.innerWidth; canvas.height=window.innerHeight; }
resize(); window.addEventListener('resize',resize);

const PTS=[];
for(let i=0;i<130;i++) PTS.push({
  x:Math.random()*window.innerWidth, y:Math.random()*window.innerHeight,
  vx:(Math.random()-.5)*.5, vy:(Math.random()-.5)*.5,
  sz:Math.random()*2+.5, op:Math.random()*.6+.1,
  red:Math.random()>.5, pulse:Math.random()*Math.PI*2, ps:Math.random()*.022+.008
});
const HEXS=[];
for(let i=0;i<7;i++) HEXS.push({
  x:Math.random()*window.innerWidth, y:Math.random()*window.innerHeight,
  r:Math.random()*85+28, op:Math.random()*.045+.01,
  rot:Math.random()*Math.PI*2, rs:(Math.random()-.5)*.003
});
function hex(x,y,r,rot,op){
  ctx.save(); ctx.translate(x,y); ctx.rotate(rot); ctx.beginPath();
  for(let i=0;i<6;i++){const a=i*Math.PI/3; ctx.lineTo(Math.cos(a)*r,Math.sin(a)*r);}
  ctx.closePath(); ctx.strokeStyle=`rgba(224,0,27,${op})`; ctx.lineWidth=1; ctx.stroke(); ctx.restore();
}
let fr=0;
function draw(){
  requestAnimationFrame(draw); fr++;
  const g=ctx.createRadialGradient(canvas.width/2,canvas.height/2,0,canvas.width/2,canvas.height/2,canvas.width*.8);
  g.addColorStop(0,'#0d0000'); g.addColorStop(.5,'#050000'); g.addColorStop(1,'#000');
  ctx.fillStyle=g; ctx.fillRect(0,0,canvas.width,canvas.height);
  // hex
  HEXS.forEach(h=>{h.rot+=h.rs; hex(h.x,h.y,h.r,h.rot,h.op); hex(h.x,h.y,h.r*.6,-h.rot*1.4,h.op*.5);});
  // grid
  ctx.strokeStyle='rgba(224,0,27,0.038)'; ctx.lineWidth=.5;
  for(let x=0;x<canvas.width;x+=60){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,canvas.height);ctx.stroke();}
  for(let y=0;y<canvas.height;y+=60){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(canvas.width,y);ctx.stroke();}
  // scan line
  const sy=(fr*1.6)%canvas.height;
  const sg=ctx.createLinearGradient(0,sy-80,0,sy+10);
  sg.addColorStop(0,'rgba(224,0,27,0)'); sg.addColorStop(1,'rgba(224,0,27,0.055)');
  ctx.fillStyle=sg; ctx.fillRect(0,sy-80,canvas.width,92);
  // particles
  const reds=[];
  PTS.forEach(p=>{
    p.x+=p.vx; p.y+=p.vy; p.pulse+=p.ps;
    const o=p.op*(.72+.28*Math.sin(p.pulse));
    if(p.x<0)p.x=canvas.width; if(p.x>canvas.width)p.x=0;
    if(p.y<0)p.y=canvas.height; if(p.y>canvas.height)p.y=0;
    ctx.beginPath(); ctx.arc(p.x,p.y,p.sz,0,Math.PI*2);
    ctx.fillStyle=p.red?`rgba(224,0,27,${o})`:`rgba(255,255,255,${o*.45})`;
    ctx.fill();
    if(p.red) reds.push(p);
  });
  // connections
  for(let i=0;i<reds.length;i++) for(let j=i+1;j<reds.length;j++){
    const dx=reds[i].x-reds[j].x, dy=reds[i].y-reds[j].y, d=Math.sqrt(dx*dx+dy*dy);
    if(d<115){ ctx.beginPath(); ctx.moveTo(reds[i].x,reds[i].y); ctx.lineTo(reds[j].x,reds[j].y);
      ctx.strokeStyle=`rgba(224,0,27,${.11*(1-d/115)})`; ctx.lineWidth=.5; ctx.stroke(); }
  }
  // center glow
  const cg=ctx.createRadialGradient(canvas.width/2,canvas.height/2,0,canvas.width/2,canvas.height/2,canvas.width*.38);
  cg.addColorStop(0,`rgba(139,0,0,${.04+.02*Math.sin(fr*.01)})`); cg.addColorStop(1,'rgba(139,0,0,0)');
  ctx.fillStyle=cg; ctx.fillRect(0,0,canvas.width,canvas.height);
}
draw();

