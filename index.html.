<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Annapurna Vandar Work</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --red:#e0001b; --red-deep:#8b0000; --red-bright:#ff1a35;
  --red-glow:rgba(224,0,27,0.4); --black:#000; --black-mid:#111;
  --black-card:#1a0408; --white:#fff; --white-dim:#ccc;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--black);color:var(--white);font-family:'Rajdhani',sans-serif;overflow-x:hidden;cursor:crosshair;}

/* ── WATERMARK ── */
.watermark{position:fixed;bottom:18px;right:22px;z-index:9998;font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;color:rgba(224,0,27,0.4);writing-mode:vertical-rl;transform:rotate(180deg);pointer-events:none;text-transform:uppercase;border-left:1px solid rgba(224,0,27,0.18);padding-left:8px;}
.watermark span{display:block;font-size:7px;opacity:.6;letter-spacing:2px;}

/* ── TOAST ── */
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(0,160,0,.15);border:1px solid rgba(0,200,0,.4);color:#5f5;font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:2px;padding:12px 26px;z-index:99999;display:none;white-space:nowrap;}
.toast.err{background:rgba(224,0,27,.15);border-color:rgba(224,0,27,.4);color:var(--red);}

/* ════════════════════════════════
   MAIN SITE PAGES (tab system)
════════════════════════════════ */
.page{display:none;min-height:100vh;}
.page.active{display:block;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:16px 48px;background:rgba(0,0,0,.97);border-bottom:1px solid rgba(224,0,27,.28);backdrop-filter:blur(12px);}
.nav-logo{font-family:'Cinzel Decorative',serif;font-size:17px;color:var(--red);text-shadow:0 0 20px var(--red-glow);letter-spacing:2px;line-height:1.2;cursor:pointer;}
.nav-logo span{display:block;font-size:9px;letter-spacing:5px;color:var(--white-dim);font-family:'Rajdhani',sans-serif;font-weight:300;}
.nav-links{display:flex;gap:4px;align-items:center;}
.nav-tab{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:2.5px;color:var(--white-dim);text-decoration:none;padding:8px 16px;border:1px solid transparent;transition:all .25s;text-transform:uppercase;cursor:pointer;background:none;position:relative;overflow:hidden;}
.nav-tab::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--red);transition:width .3s;}
.nav-tab:hover,.nav-tab.active-tab{color:var(--red);border-color:rgba(224,0,27,.35);}
.nav-tab.active-tab::after,.nav-tab:hover::after{width:100%;}
.admin-btn{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:2px;color:rgba(224,0,27,.65);background:transparent;border:1px solid rgba(224,0,27,.22);padding:7px 14px;cursor:pointer;transition:all .25s;text-transform:uppercase;margin-left:8px;}
.admin-btn:hover{color:var(--red);border-color:var(--red);background:rgba(224,0,27,.06);}

/* ════════════════════════════════
   HOME PAGE
════════════════════════════════ */
#page-home{position:relative;overflow:hidden;}
#hero-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:0;}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,0,0,.87) 0%,rgba(139,0,0,.09) 50%,rgba(0,0,0,.9) 100%);z-index:1;}
.hero-content{position:relative;z-index:2;text-align:center;padding:0 20px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;}
.hero-badge{display:inline-block;font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:6px;color:var(--red);border:1px solid var(--red-glow);padding:6px 20px;margin-bottom:28px;animation:fiu .9s ease .2s both;}
.hero-title{font-family:'Cinzel Decorative',serif;font-size:clamp(34px,7vw,88px);font-weight:900;line-height:1.05;color:var(--white);margin-bottom:10px;animation:fid .9s ease .4s both;}
.hero-title .red{color:var(--red);text-shadow:0 0 30px var(--red-glow),0 0 60px rgba(224,0,27,.14);}
.hero-sub{font-size:clamp(11px,1.8vw,17px);letter-spacing:7px;color:var(--white-dim);text-transform:uppercase;margin-bottom:48px;animation:fid .9s ease .6s both;}
.hero-cta{display:flex;gap:18px;flex-wrap:wrap;justify-content:center;animation:fid .9s ease .8s both;}
.btn-p{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;padding:13px 34px;background:var(--red);color:#fff;border:none;cursor:pointer;text-transform:uppercase;text-decoration:none;position:relative;overflow:hidden;transition:all .3s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);display:inline-block;}
.btn-p::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:translateX(-100%);transition:transform .5s;}
.btn-p:hover::before{transform:translateX(100%);}
.btn-p:hover{background:var(--red-bright);box-shadow:0 0 28px var(--red-glow);}
.btn-s{font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;padding:13px 34px;background:transparent;color:var(--red);border:1px solid var(--red);cursor:pointer;text-transform:uppercase;text-decoration:none;transition:all .3s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);display:inline-block;}
.btn-s:hover{background:rgba(224,0,27,.1);box-shadow:0 0 18px rgba(224,0,27,.2);}
.scroll-ind{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;animation:fadeIn 2s ease 1.5s both;}
.scroll-ind span{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:4px;color:rgba(224,0,27,.6);}
.scroll-line{width:1px;height:48px;background:linear-gradient(180deg,var(--red),transparent);animation:scpulse 2s ease infinite;}

/* ════════════════════════════════
   SERVICE PAGE
════════════════════════════════ */
#page-service{padding:130px 50px 100px;background:linear-gradient(180deg,var(--black) 0%,#111 50%,var(--black) 100%);position:relative;}
.grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(224,0,27,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(224,0,27,.03) 1px,transparent 1px);background-size:50px 50px;pointer-events:none;}
.sec-hdr{text-align:center;margin-bottom:65px;position:relative;z-index:1;}
.sec-eye{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:6px;color:var(--red);text-transform:uppercase;display:block;margin-bottom:14px;}
.sec-ttl{font-family:'Cinzel Decorative',serif;font-size:clamp(26px,4vw,50px);color:var(--white);line-height:1.2;}
.sec-div{width:60px;height:2px;background:linear-gradient(90deg,transparent,var(--red),transparent);margin:18px auto 0;}
.srv-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:22px;max-width:1200px;margin:0 auto;position:relative;z-index:1;}
.srv-card{background:var(--black-card);border:1px solid rgba(224,0,27,.2);padding:38px 28px;position:relative;overflow:hidden;transition:all .4s;}
.srv-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:0;background:var(--red);transition:height .4s;}
.srv-card:hover{border-color:rgba(224,0,27,.5);transform:translateY(-5px);box-shadow:0 18px 55px rgba(0,0,0,.5),0 0 28px rgba(224,0,27,.1);}
.srv-card:hover::before{height:100%;}
.srv-ico{font-size:34px;margin-bottom:18px;display:block;filter:drop-shadow(0 0 9px rgba(224,0,27,.4));}
.srv-num{font-family:'Orbitron',sans-serif;font-size:40px;color:rgba(224,0,27,.07);font-weight:900;position:absolute;top:14px;right:18px;}
.srv-card h3{font-family:'Cinzel Decorative',serif;font-size:15px;color:var(--red);margin-bottom:10px;}
.srv-card p{font-size:13px;color:var(--white-dim);line-height:1.7;font-weight:300;}

/* ════════════════════════════════
   NOTICE PAGE (PUBLIC)
════════════════════════════════ */
#page-notice{padding:130px 50px 100px;background:var(--black);}
.notice-board{max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:14px;}
.notice-item{background:var(--black-card);border:1px solid rgba(224,0,27,.15);border-left:3px solid var(--red);padding:20px 24px;display:flex;align-items:flex-start;gap:18px;animation:slideL .45s ease;transition:all .3s;}
.notice-item:hover{border-color:rgba(224,0,27,.4);background:rgba(139,0,0,.05);}
.nbadge{font-family:'Orbitron',sans-serif;font-size:7px;letter-spacing:2px;padding:4px 10px;text-transform:uppercase;white-space:nowrap;flex-shrink:0;margin-top:3px;}
.b-urgent{background:var(--red);color:#fff;}
.b-info{background:transparent;color:var(--red);border:1px solid var(--red);}
.b-update{background:rgba(224,0,27,.2);color:var(--red);}
.b-general{background:transparent;color:#888;border:1px solid #333;}
.nc{flex:1;}
.nc h4{font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:600;color:var(--white);margin-bottom:5px;}
.nc p{font-size:13px;color:var(--white-dim);line-height:1.6;font-weight:300;}
.nc-meta{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:2px;color:rgba(224,0,27,.5);margin-top:8px;}
.empty-n{text-align:center;padding:50px;font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:3px;color:rgba(255,255,255,.13);}

/* ════════════════════════════════
   BOOKING PAGE
════════════════════════════════ */
#page-booking{padding:130px 50px 100px;background:linear-gradient(180deg,var(--black) 0%,rgba(139,0,0,.04) 50%,var(--black) 100%);}
.bk-wrap{max-width:820px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;border:1px solid rgba(224,0,27,.3);overflow:hidden;}
.bk-left{background:var(--red);padding:48px 38px;display:flex;flex-direction:column;justify-content:center;}
.bk-left h3{font-family:'Cinzel Decorative',serif;font-size:21px;color:#fff;margin-bottom:18px;}
.bk-left p{font-size:13px;color:rgba(255,255,255,.82);line-height:1.7;font-weight:300;margin-bottom:28px;}
.bk-feats{list-style:none;}
.bk-feats li{display:flex;align-items:center;gap:9px;font-size:13px;color:rgba(255,255,255,.92);margin-bottom:9px;}
.bk-feats li::before{content:'▶';font-size:7px;color:rgba(255,255,255,.6);}
.bk-right{background:var(--black-card);padding:48px 38px;}
.f-field{margin-bottom:18px;}
.f-lbl{display:block;font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:3px;color:var(--red);margin-bottom:7px;text-transform:uppercase;}
.f-inp{width:100%;background:rgba(0,0,0,.6);border:1px solid rgba(224,0,27,.22);border-bottom:1px solid rgba(224,0,27,.5);color:#fff;padding:11px 15px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none;transition:all .3s;}
.f-inp:focus{border-color:var(--red);box-shadow:0 0 14px rgba(224,0,27,.1);background:rgba(139,0,0,.05);}
.f-inp::placeholder{color:rgba(255,255,255,.18);}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.bk-submit{width:100%;padding:15px;background:var(--red);color:#fff;border:none;font-family:'Orbitron',sans-serif;font-size:10px;letter-spacing:4px;cursor:pointer;text-transform:uppercase;transition:all .3s;position:relative;overflow:hidden;margin-top:10px;}
.bk-submit::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.14),transparent);transform:translateX(-100%);transition:transform .5s;}
.bk-submit:hover::before{transform:translateX(100%);}
.bk-submit:hover{background:var(--red-bright);box-shadow:0 0 28px var(--red-glow);}
.success-msg{display:none;background:rgba(0,139,0,.1);border:1px solid rgba(0,200,0,.3);border-left:3px solid #0c0;padding:14px 18px;margin-top:14px;font-size:13px;color:#8f8;line-height:1.6;}

/* ════════════════════════════════
   ADMIN LOGIN MODAL
════════════════════════════════ */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:9100;display:none;align-items:center;justify-content:center;backdrop-filter:blur(10px);}
.modal-ov.open{display:flex;}
.modal-box{background:var(--black-card);border:1px solid rgba(224,0,27,.42);padding:50px 44px;width:100%;max-width:420px;position:relative;animation:fid .4s ease;}
.modal-box::before{content:'ADMIN ACCESS';position:absolute;top:-12px;left:50%;transform:translateX(-50%);font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:5px;background:var(--red);color:#fff;padding:4px 16px;white-space:nowrap;}
.modal-box h2{font-family:'Cinzel Decorative',serif;font-size:21px;color:var(--red);text-align:center;margin-bottom:6px;}
.modal-box .sub{text-align:center;font-size:10px;color:rgba(255,255,255,.25);letter-spacing:3px;margin-bottom:32px;font-family:'Orbitron',sans-serif;}
.m-field{margin-bottom:18px;}
.m-lbl{display:block;font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:3px;color:var(--red);margin-bottom:7px;}
.m-inp{width:100%;background:rgba(0,0,0,.7);border:1px solid rgba(224,0,27,.28);border-bottom:1px solid rgba(224,0,27,.6);color:#fff;padding:13px 15px;font-family:'Rajdhani',sans-serif;font-size:15px;outline:none;transition:all .3s;letter-spacing:1px;}
.m-inp:focus{border-color:var(--red);box-shadow:0 0 18px rgba(224,0,27,.1);}
.m-btn{width:100%;padding:15px;background:var(--red);color:#fff;border:none;font-family:'Orbitron',sans-serif;font-size:11px;letter-spacing:4px;cursor:pointer;text-transform:uppercase;transition:all .3s;margin-top:4px;}
.m-btn:hover{background:var(--red-bright);box-shadow:0 0 28px var(--red-glow);}
.m-err{color:#f66;font-size:11px;text-align:center;margin-top:11px;font-family:'Orbitron',sans-serif;letter-spacing:1px;display:none;}
.m-close{position:absolute;top:13px;right:15px;background:none;border:none;color:rgba(224,0,27,.5);font-size:17px;cursor:pointer;line-height:1;}
.m-close:hover{color:var(--red);}

/* ════════════════════════════════
   ADMIN DASHBOARD
════════════════════════════════ */
#admin-dash{position:fixed;inset:0;background:var(--black);z-index:9000;display:none;flex-direction:column;overflow:hidden;}
#admin-dash.open{display:flex;}
.dash-hdr{background:rgba(0,0,0,.99);border-bottom:1px solid rgba(224,0,27,.28);padding:0 40px;display:flex;align-items:stretch;justify-content:space-between;flex-shrink:0;}
.dash-logo-wrap{display:flex;flex-direction:column;justify-content:center;padding:16px 0;}
.dash-logo{font-family:'Cinzel Decorative',serif;font-size:16px;color:var(--red);}
.dash-logo span{font-family:'Orbitron',sans-serif;font-size:7px;letter-spacing:4px;color:rgba(255,255,255,.25);display:block;margin-top:2px;}
/* Dash Tabs */
.dash-tabs{display:flex;align-items:stretch;gap:0;}
.d-tab{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:2px;padding:0 22px;background:none;border:none;color:rgba(255,255,255,.35);cursor:pointer;text-transform:uppercase;border-bottom:2px solid transparent;transition:all .25s;display:flex;align-items:center;}
.d-tab:hover{color:var(--white-dim);}
.d-tab.active{color:var(--red);border-bottom-color:var(--red);}
.dash-actions{display:flex;gap:10px;align-items:center;}
.d-act-btn{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:2px;padding:7px 16px;background:transparent;border:1px solid rgba(224,0,27,.3);color:var(--red);cursor:pointer;text-transform:uppercase;transition:all .2s;}
.d-act-btn:hover{background:rgba(224,0,27,.08);}
.d-act-btn.out{border-color:rgba(255,255,255,.15);color:rgba(255,255,255,.35);}
.d-act-btn.out:hover{border-color:var(--red);color:var(--red);}
/* Dash Body */
.dash-body{flex:1;overflow-y:auto;padding:36px 40px;}
.dash-panel{display:none;}
.dash-panel.active{display:block;}
/* Stats */
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:18px;margin-bottom:36px;}
.stat-c{background:var(--black-card);border:1px solid rgba(224,0,27,.18);padding:24px;position:relative;overflow:hidden;}
.stat-c::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--red);}
.s-num{font-family:'Orbitron',sans-serif;font-size:34px;color:var(--red);font-weight:700;line-height:1;}
.s-lbl{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:2px;margin-top:7px;font-family:'Orbitron',sans-serif;text-transform:uppercase;}
/* Booking table */
.d-sec-ttl{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:4px;color:var(--red);border-bottom:1px solid rgba(224,0,27,.18);padding-bottom:11px;margin-bottom:18px;}
.bk-tbl{width:100%;border-collapse:collapse;}
.bk-tbl th{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:2px;color:rgba(255,255,255,.35);padding:9px 14px;text-align:left;border-bottom:1px solid rgba(224,0,27,.12);}
.bk-tbl td{padding:13px 14px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--white-dim);}
.bk-tbl tr:hover td{background:rgba(224,0,27,.03);}
.stbadge{font-family:'Orbitron',sans-serif;font-size:7px;letter-spacing:1px;padding:3px 9px;}
.st-new{background:rgba(224,0,27,.14);color:var(--red);border:1px solid rgba(224,0,27,.3);}
.st-done{background:rgba(0,180,0,.1);color:#5f5;border:1px solid rgba(0,180,0,.3);}
.tbtn{background:none;border:none;cursor:pointer;font-size:12px;transition:color .2s;}
.tbtn.del{color:rgba(224,0,27,.3);} .tbtn.del:hover{color:var(--red);}
.tbtn.ok{color:rgba(0,200,0,.4);border:1px solid rgba(0,200,0,.3);font-family:'Orbitron',sans-serif;font-size:8px;padding:3px 9px;letter-spacing:1px;} .tbtn.ok:hover{color:#5f5;background:rgba(0,180,0,.08);}
.empty-row td{text-align:center;color:rgba(255,255,255,.12);font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:2px;padding:30px;}
/* Notice form in dash */
.d-form{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.d-form .full{grid-column:1/-1;}
.d-inp{width:100%;background:rgba(0,0,0,.65);border:1px solid rgba(224,0,27,.18);color:#fff;padding:10px 13px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none;transition:border-color .3s;resize:vertical;}
.d-inp:focus{border-color:var(--red);}
.d-sel{width:100%;background:#0a0000;border:1px solid rgba(224,0,27,.18);color:#fff;padding:10px 13px;font-family:'Rajdhani',sans-serif;font-size:14px;outline:none;}
.d-btn{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:3px;padding:11px 26px;background:var(--red);color:#fff;border:none;cursor:pointer;text-transform:uppercase;transition:all .3s;}
.d-btn:hover{background:var(--red-bright);box-shadow:0 0 22px var(--red-glow);}
/* Notice list in dash */
.d-notice-item{background:var(--black-card);border:1px solid rgba(224,0,27,.13);border-left:3px solid var(--red);padding:14px 18px;display:flex;align-items:center;gap:14px;margin-bottom:10px;}
.d-notice-item:last-child{margin-bottom:0;}
.dn-info{flex:1;}
.dn-ttl{font-weight:600;color:#fff;font-size:14px;margin-bottom:2px;}
.dn-body{font-size:12px;color:rgba(255,255,255,.45);}
/* Image upload in notice */
.img-upload-area{border:1.5px dashed rgba(224,0,27,.35);padding:18px;text-align:center;cursor:pointer;transition:all .3s;position:relative;background:rgba(139,0,0,.04);}
.img-upload-area:hover{border-color:var(--red);background:rgba(139,0,0,.08);}
.img-upload-area input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.img-upload-area .upl-lbl{font-family:'Orbitron',sans-serif;font-size:8px;letter-spacing:2px;color:rgba(224,0,27,.6);display:block;margin-bottom:4px;}
.img-upload-area .upl-hint{font-size:11px;color:rgba(255,255,255,.2);}
#imgPreview{width:100%;max-height:140px;object-fit:cover;display:none;border:1px solid rgba(224,0,27,.2);margin-top:8px;}
/* Public notice image */
.notice-img{width:100%;max-height:200px;object-fit:cover;border:1px solid rgba(224,0,27,.15);margin-top:10px;display:block;}
/* Booking confirm badge */
.confirm-wa-btn{background:rgba(37,211,102,.12);border:1px solid rgba(37,211,102,.35);color:#25d366;font-family:'Orbitron',sans-serif;font-size:8px;padding:4px 10px;cursor:pointer;letter-spacing:1px;transition:all .2s;}
.confirm-wa-btn:hover{background:rgba(37,211,102,.22);box-shadow:0 0 12px rgba(37,211,102,.2);}


/* ════════════════════════════════
   FOOTER
════════════════════════════════ */
