    `━━━━━━━━━━━━━━━━━━━━\n`+
    `👤 *Customer Name:* ${name}\n`+
    `📅 *Date:* ${fDate}\n`+
    `🕐 *Time:* ${fTime}\n`+
    `📍 *Address:* ${addr}\n`+
    (phone?`📱 *Phone:* ${phone}\n`:'')+
    `━━━━━━━━━━━━━━━━━━━━\n`+
