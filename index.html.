<script>
/* ══════════════════════════════════════
   STATE
══════════════════════════════════════ */
const ADMIN_WA = '917432923093';
let isAdmin = false;
let bookings = [];
let notices  = [
  { id:1, type:'info',   title:'Welcome to Annapurna Vandar Work', body:'আমাদের অনলাইন প্ল্যাটফর্মে আপনাকে স্বাগতম। সেরা সেবা পেতে আজই স্লট বুক করুন।', date:today() },
  { id:2, type:'urgent', title:'Slot Booking Now Open',             body:'নতুন স্লট বুকিং চালু হয়েছে। আগে আসলে আগে পাবেন ভিত্তিতে সিট নিশ্চিত করুন।',   date:today() },
];

function today(){ return new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}); }

/* ══════════════════════════════════════
   PAGE TAB NAVIGATION
══════════════════════════════════════ */
function showPage(id, btn) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active-tab'));
  if(btn){ btn.classList.add('active-tab'); }
  else {
    // find matching tab
    document.querySelectorAll('.nav-tab').forEach(t=>{
      if(t.textContent.trim().toLowerCase()===id) t.classList.add('active-tab');
    });
  }
  window.scrollTo(0,0);
  // Resize canvas if going to home
  if(id==='home') resize();
}

/* ══════════════════════════════════════
   TOAST
══════════════════════════════════════ */
function showToast(msg, err=false){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast'+(err?' err':'');
  t.style.display='block';
  clearTimeout(t._t);
  t._t=setTimeout(()=>t.style.display='none',3200);
}

/* ══════════════════════════════════════
   ADMIN AUTH
══════════════════════════════════════ */
function openLogin(){
  document.getElementById('loginModal').classList.add('open');
  document.getElementById('aUser').value='';
  document.getElementById('aPass').value='';
  document.getElementById('loginErr').style.display='none';
  setTimeout(()=>document.getElementById('aUser').focus(),120);
}
function closeLogin(){ document.getElementById('loginModal').classList.remove('open'); }
function doLogin(){
  const u=document.getElementById('aUser').value.trim();
  const p=document.getElementById('aPass').value.trim();
  if(u==='admin' && p==='rahul99'){
    isAdmin=true; closeLogin();
    openDash();
  } else {
    document.getElementById('loginErr').style.display='block';
    document.getElementById('aPass').value='';
    document.getElementById('aPass').focus();
  }
}
function adminLogout(){
  isAdmin=false;
  document.getElementById('admin-dash').classList.remove('open');
  document.getElementById('mainNav').style.display='flex';
  document.getElementById('mainFooter').style.display='block';
  showToast('LOGGED OUT');
}
function exitDash(){
  document.getElementById('admin-dash').classList.remove('open');
  document.getElementById('mainNav').style.display='flex';
  document.getElementById('mainFooter').style.display='block';
}

/* ══════════════════════════════════════
   ADMIN DASHBOARD
══════════════════════════════════════ */
function openDash(){
  document.getElementById('admin-dash').classList.add('open');
  document.getElementById('mainNav').style.display='none';
  document.getElementById('mainFooter').style.display='none';
  // show overview by default
  showDashPanel('overview', document.querySelector('.d-tab'));
  renderStats(); renderOvTable(); renderFullTable(); renderDashNotices();
}
function showDashPanel(id, btn){
  document.querySelectorAll('.dash-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('dp-'+id).classList.add('active');
  document.querySelectorAll('.d-tab').forEach(t=>t.classList.remove('active'));
  if(btn) btn.classList.add('active');
}
function renderStats(){
  document.getElementById('st-total').textContent  = bookings.length;
  document.getElementById('st-new').textContent    = bookings.filter(b=>b.status==='new').length;
  document.getElementById('st-done').textContent   = bookings.filter(b=>b.status==='done').length;
  document.getElementById('st-notice').textContent = notices.length;
}
function renderOvTable(){
  const tb=document.getElementById('ov-tbody');
  if(!bookings.length){ tb.innerHTML='<tr class="empty-row"><td colspan="6">NO BOOKINGS YET</td></tr>'; return; }
  tb.innerHTML=[...bookings].reverse().slice(0,5).map((b,i)=>`
    <tr>
      <td style="color:rgba(224,0,27,.5);font-family:'Orbitron',sans-serif;font-size:9px;">${String(bookings.length-i).padStart(2,'0')}</td>
      <td style="color:#fff;font-weight:600;">${b.name}</td>
      <td>${b.date}</td><td>${b.time}</td><td>${b.phone||'—'}</td>
      <td><span class="stbadge ${b.status==='done'?'st-done':'st-new'}">${b.status==='done'?'CONFIRMED':'NEW'}</span></td>
    </tr>`).join('');
}
function renderFullTable(){
  const tb=document.getElementById('full-tbody');
  if(!bookings.length){ tb.innerHTML='<tr class="empty-row"><td colspan="8">NO BOOKINGS YET</td></tr>'; return; }
  tb.innerHTML=[...bookings].reverse().map((b,i)=>`
    <tr>
      <td style="color:rgba(224,0,27,.5);font-family:'Orbitron',sans-serif;font-size:9px;">${String(bookings.length-i).padStart(2,'0')}</td>
      <td style="color:#fff;font-weight:600;">${b.name}</td>
      <td>${b.date}</td><td>${b.time}</td>
      <td style="max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${b.addr}</td>
      <td>${b.phone||'—'}</td>
      <td><span class="stbadge ${b.status==='done'?'st-done':'st-new'}">${b.status==='done'?'CONFIRMED':'NEW'}</span></td>
      <td style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        ${b.status!=='done'?`<button class="tbtn ok" onclick="confirmBk(${b.id})">✓ Confirm</button>`:''}
        <button class="confirm-wa-btn" onclick="sendConfirmWA(${b.id})" title="Send Confirmation via WhatsApp">✉ WA</button>
        <button class="tbtn del" onclick="deleteBk(${b.id})">✕</button>
      </td>
    </tr>`).join('');
}
function confirmBk(id){
  const b=bookings.find(x=>x.id===id);
  if(b){ b.status='done'; }
  renderStats(); renderOvTable(); renderFullTable();
  showToast('✓ BOOKING CONFIRMED');
}
function sendConfirmWA(id){
  const b=bookings.find(x=>x.id===id);
  if(!b) return;
  const msg=
    `✅ *BOOKING CONFIRMED*\n`+
    `━━━━━━━━━━━━━━━━━━━━\n`+
    `🌺 *ANNAPURNA VANDAR WORK*\n`+
    `━━━━━━━━━━━━━━━━━━━━\n`+
    `👤 *Customer:* ${b.name}\n`+
    `📅 *Date:* ${b.date}\n`+
    `🕐 *Time:* ${b.time}\n`+
    `📍 *Address:* ${b.addr}\n`+
    (b.phone&&b.phone!=='—'?`📱 *Phone:* ${b.phone}\n`:'')+
    `━━━━━━━━━━━━━━━━━━━━\n`+
    `_আপনার বুকিং নিশ্চিত হয়েছে। ধন্যবাদ!_`;
  const waNum = b.phone && b.phone!=='—' ? b.phone.replace(/\D/g,'') : ADMIN_WA;
  window.open(`https://wa.me/${waNum.startsWith('91')?waNum:'91'+waNum}?text=${encodeURIComponent(msg)}`,'_blank');
  if(b.status!=='done'){ b.status='done'; renderStats(); renderOvTable(); renderFullTable(); }
  showToast('✓ CONFIRMATION SENT VIA WHATSAPP');
}
function deleteBk(id){ bookings=bookings.filter(x=>x.id!==id); renderStats();renderOvTable();renderFullTable();showToast('BOOKING DELETED',true); }

/* ══════════════════════════════════════
   NOTICE SYSTEM
══════════════════════════════════════ */
const badgeMap={
  urgent:{cls:'b-urgent',label:'Urgent'},
  info:{cls:'b-info',label:'Info'},
  update:{cls:'b-update',label:'Update'},
  general:{cls:'b-general',label:'General'},
};

let pendingImgData = null; // stores base64 image

function previewImage(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    pendingImgData = e.target.result;
    const prev = document.getElementById('imgPreview');
    prev.src = pendingImgData;
    prev.style.display = 'block';
    document.getElementById('uploadArea').querySelector('.upl-lbl').textContent = '✅ IMAGE SELECTED';
  };
  reader.readAsDataURL(file);
}
function clearImage(){
  pendingImgData = null;
  document.getElementById('noticeImg').value = '';
  const prev = document.getElementById('imgPreview');
  prev.src = ''; prev.style.display = 'none';
  document.getElementById('uploadArea').querySelector('.upl-lbl').textContent = '📷 CLICK TO UPLOAD IMAGE';
}

function renderPublicNotices(){
  const board=document.getElementById('noticeBoard');
  const empty=document.getElementById('emptyNotice');
  board.querySelectorAll('.notice-item').forEach(el=>el.remove());
  if(!notices.length){ empty.style.display='block'; return; }
  empty.style.display='none';
  [...notices].reverse().forEach(n=>{
    const b=badgeMap[n.type];
    const el=document.createElement('div');
    el.className='notice-item';
    el.innerHTML=`<span class="nbadge ${b.cls}">${b.label}</span>
      <div class="nc">
        <h4>${n.title}</h4>
        <p>${n.body}</p>
        ${n.img?`<img class="notice-img" src="${n.img}" alt="Notice Image">`:''}
        <div class="nc-meta">Posted · ${n.date}</div>
      </div>`;
    board.appendChild(el);
  });
}
function renderDashNotices(){
  const list=document.getElementById('d-notice-list');
  if(!notices.length){ list.innerHTML='<div class="empty-n">No notices posted yet</div>'; return; }
  list.innerHTML=[...notices].reverse().map(n=>{
    const b=badgeMap[n.type];
    return `<div class="d-notice-item">
      <span class="nbadge ${b.cls}">${b.label}</span>
      ${n.img?`<img src="${n.img}" style="width:54px;height:40px;object-fit:cover;border:1px solid rgba(224,0,27,.2);flex-shrink:0;" alt="">`:''}
      <div class="dn-info">
        <div class="dn-ttl">${n.title}</div>
        <div class="dn-body">${n.body.slice(0,80)}${n.body.length>80?'...':''}</div>
      </div>
      <button class="tbtn del" onclick="deleteNotice(${n.id})" title="Delete">✕</button>
    </div>`;
  }).join('');
}
function adminPostNotice(){
  const title=document.getElementById('dTitle').value.trim();
  const body=document.getElementById('dBody').value.trim();
  const type=document.getElementById('dType').value;
  if(!title||!body){ showToast('Fill title and body',true); return; }
  notices.push({id:Date.now(),type,title,body,img:pendingImgData||null,date:today()});
  document.getElementById('dTitle').value='';
  document.getElementById('dBody').value='';
  clearImage();
  renderPublicNotices(); renderDashNotices(); renderStats();
  showToast('✓ NOTICE POSTED TO WEBSITE');
}
function deleteNotice(id){
  notices=notices.filter(n=>n.id!==id);
  renderPublicNotices(); renderDashNotices(); renderStats();
  showToast('NOTICE DELETED',true);
}

